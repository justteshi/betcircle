{# templates/shop/account/wallet/index.html.twig #}
{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}Wallet | {{ parent() }}{% endblock %}

{% block content %}
    <div class="container my-5">
        <div class="mb-4">
            {% include '@SyliusShop/account/common/content/breadcrumbs.html.twig' %}
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-3">
                {% include '@SyliusShop/account/common/content/menu/account.html.twig' %}
            </div>

            <div class="col-12 col-lg-9">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted small">
                                <i class="ti ti-wallet me-1"></i>
                                Wallet balance
                            </div>

                            <div class="d-flex align-items-center gap-2 mb-0">
                                <img src="{{ asset('images/tokens/token_template_cropped.png') }}" alt="BetCircle" style="height:2rem;">
                                <div class="h4 mb-0">{{ wallet_balance() }} </div>
                                <span class="text-muted" style="font-size: 10px">tokens</span>
                            </div>

                        </div>

                        <div class="text-end text-muted small">
                            <i class="ti ti-coins me-1"></i>
                            BetCircle Wallet
                        </div>
                    </div>
                </div>

                <div class="card shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="mb-3">
                            <i class="ti ti-receipt me-2"></i>
                            Transactions
                        </h5>

                        {% if transactions is empty %}
                            <div class="text-muted">No wallet transactions yet.</div>
                        {% else %}
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Type</th>
                                        <th>Direction</th>
                                        <th>Amount</th>
                                        <th>Description</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    {% for transaction in transactions %}
                                        <tr>
                                            <td>{{ transaction.createdAt|date('Y-m-d H:i') }}</td>
                                            <td>{{ transaction.typeValue|replace({'_': ' '})|title }}</td>
                                            <td>
                                                {% if transaction.directionValue == 'credit' %}
                                                    <span class="badge text-bg-success">
                                                        {{ ux_icon('tabler:plus', { class: 'me-1' }) }}
                                                        Credit
                                                    </span>
                                                {% else %}
                                                    <span class="badge text-bg-danger">
                                                       {{ ux_icon('tabler:minus', { class: 'me-1' }) }}
                                                        Debit
                                                    </span>
                                                {% endif %}
                                            </td>
                                            <td>{{ transaction.amount }}</td>
                                            <td>{{ transaction.description ?: '—' }}</td>
                                        </tr>
                                    {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
