{% extends '@SyliusShop/shared/layout/base.html.twig' %}

{% block title %}Game Weeks | {{ parent() }}{% endblock %}

{% block content %}
    <div class="container my-5">
        <h1 class="mb-4">Game Weeks</h1>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger">{{ message }}</div>
        {% endfor %}

        <div class="row">
            {% for week in weeks %}
                {% set joinClosed = week.joinDeadlineAt and week.joinDeadlineAt < date() %}
                {% set alreadyJoined = week.id in joinedWeekIds %}

                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">
                                <a href="{{ path('app_shop_gameweeks_show', { id: week.id }) }}" class="text-decoration-none">
                                    {{ week.name }}
                                </a>

                                {% if alreadyJoined %}
                                    <span class="badge bg-success ms-2">Joined</span>
                                {% elseif joinClosed %}
                                    <span class="badge bg-secondary ms-2">Closed</span>
                                {% endif %}
                            </h5>

                            <p class="text-muted mb-2">
                                Entry cost:
                                <strong>{{ week.entryCostTokens }} TOKENS</strong>
                            </p>

                            <p class="text-muted mb-2">
                                Weekly pool:
                                <strong>{{ week.weeklyPoolTokens }} TOKENS</strong>
                            </p>

                            <p class="text-muted mb-2">
                                Seasonal contribution:
                                <strong>{{ week.seasonalPoolContributionTokens }} TOKENS</strong>
                            </p>

                            <p class="text-muted mb-3">
                                Join deadline:
                                {{ week.joinDeadlineAt ? week.joinDeadlineAt|date('Y-m-d H:i') : '—' }}
                            </p>

                            <div class="mt-auto">
                                <a href="{{ path('app_shop_gameweeks_show', { id: week.id }) }}" class="btn btn-outline-dark w-100">
                                    View Game Week
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-12">
                    <p>No game weeks available.</p>
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
